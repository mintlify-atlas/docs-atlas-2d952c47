  "keyFeatures": [
    "Multi-step online booking with real-time price calculation",
    "Admin dashboard with calendar and reservation management",
    "Dynamic pricing engine with vehicle coefficients and service rates",
    "Dual authentication (classic login + Firebase social auth)",
    "Complete reservation lifecycle (PENDING → IN PROGRESS → COMPLETED)",
    "Photo evidence system for vehicle condition",
    "Automated email notifications via n8n webhooks",
    "User profile with virtual garage and reservation history",
    "Subscription plans (quarterly, semi-annual, annual)",
    "Additional services catalog (car wash, EV charging, refueling, ITV)"
  ],
  "publicApiSurface": [
    "POST /api/pricing/dynamic",
    "POST /api/reservations/public-new",
    "GET /api/reservations (admin)",
    "PricingService.calculateTotalPrice()",
    "customerDAO.create()",
    "reservationDAO.create()",
    "vehicleDAO.create()",
    "notificationService.send()"
